PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=your-jwt-secret

SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

INTERVIEW_SERVICE_URL=http://localhost:8001

# After each candidate text answer, generate the next question automatically (default on). Set to false for manual-only.
# INTERVIEW_AUTO_NEXT=true
# Cap total AI questions per session (default 25).
# INTERVIEW_MAX_QUESTIONS=25

# Judge0 CE - Hosted API (no Docker)
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=your-judge0-api-key

# Or use RapidAPI Judge0 CE:
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key
